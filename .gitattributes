# Handle line endings automatically
* text=auto

# Force LF for source code files
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Force CRLF for Windows batch files
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.eot  binary
*.pdf  binary
